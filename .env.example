# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Admin / Manual Takeover
# 管理员 Telegram user ID（用于接收订单通知和人工接管）
ADMIN_ID=0

# LLM Configuration
# Provider: openai, claude, deepseek
LLM_PROVIDER=openai
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# Notion (optional)
NOTION_ENABLED=false
# 默认关闭，开启改为true
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Context Settings
MAX_CONTEXT_TURNS=10
CONTEXT_EXPIRE_MINUTES=30

# 置信度阈值：默认60%,如果 AI 觉得自己只有 60% 的把握答对，它就会闭嘴，转而通知你手动回复
# Confidence threshold (0.0-1.0) — below this, auto-escalate to manual
CONFIDENCE_THRESHOLD=0.6

# Accounting backends (comma-separated: sqlite,notion,excel)
# 如果开启了 NOTION_ENABLED=true，此处必须包含 notion，否则订单不会同步到 Notion
ACCOUNTING_BACKENDS=sqlite

# Logging
LOG_LEVEL=INFO
